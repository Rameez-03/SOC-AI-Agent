# =============================================================================
# SOC-AI-Agent Configuration
# Copy this file to .env and fill in your values.
# Lines starting with # are comments and are ignored.
# =============================================================================

# =============================================================================
# SIEM BACKEND
# Which SIEM to pull alerts and logs from.
# Options: wazuh | elastic | none
# =============================================================================
SIEM_BACKEND=wazuh

# --- Wazuh (if SIEM_BACKEND=wazuh) ---
# API runs on port 55000, separate from the dashboard (port 443).
WAZUH_URL=https://192.168.56.10:55000
WAZUH_USER=wazuh-wui
WAZUH_PASSWORD=
# Set to false because Wazuh uses a self-signed certificate by default.
WAZUH_VERIFY_SSL=false

# --- Elastic SIEM (if SIEM_BACKEND=elastic) ---
# ELASTIC_URL=https://localhost:9200
# ELASTIC_USER=elastic
# ELASTIC_PASSWORD=
# ELASTIC_INDEX=.siem-signals-*
# ELASTIC_VERIFY_SSL=false

# =============================================================================
# CASE MANAGEMENT BACKEND
# Where your cases/incidents are tracked.
# Options: thehive | jira | none
# =============================================================================
CASE_BACKEND=thehive

# --- TheHive (if CASE_BACKEND=thehive) ---
# Use the analyst user API key, NOT the platform admin key.
# In TheHive: top-right avatar > API Key > copy or regenerate.
THEHIVE_URL=http://192.168.56.10:9000
THEHIVE_API_KEY=
THEHIVE_ORG=SOCLab

# --- Jira Service Management (if CASE_BACKEND=jira) ---
# JIRA_URL=https://your-org.atlassian.net
# JIRA_USER=your@email.com
# JIRA_TOKEN=
# JIRA_PROJECT=SOC

# =============================================================================
# ENRICHMENT BACKEND
# Where IOCs (IPs, domains, hashes) are enriched.
# Options: cortex | direct | none
#   cortex  - routes enrichment through your Cortex instance
#   direct  - calls VirusTotal and AbuseIPDB APIs directly (no Cortex needed)
#   none    - skip enrichment entirely
# =============================================================================
ENRICHMENT_BACKEND=cortex

# --- Cortex (if ENRICHMENT_BACKEND=cortex) ---
# Create a dedicated user in Cortex for the agent (read + analyze roles).
# Do NOT reuse the thehive service account.
CORTEX_URL=http://192.168.56.10:9001
CORTEX_API_KEY=

# --- Direct enrichment (if ENRICHMENT_BACKEND=direct) ---
# VIRUSTOTAL_API_KEY=
# ABUSEIPDB_API_KEY=

# =============================================================================
# SOAR BACKEND
# Automated response and workflow triggering.
# Options: shuffle | generic_webhook | none
# =============================================================================
SOAR_BACKEND=shuffle

# --- Shuffle (if SOAR_BACKEND=shuffle) ---
# Leave blank if you have no response workflows yet. The agent will document
# recommended actions but won't trigger anything until this is set.
SHUFFLE_WEBHOOK_URL=

# --- Generic webhook (if SOAR_BACKEND=generic_webhook) ---
# Any SOAR platform that accepts a JSON POST to a webhook URL.
# SOAR_WEBHOOK_URL=

# =============================================================================
# LLM / OLLAMA
# =============================================================================
# Internal Docker network address - do not change unless running Ollama externally.
OLLAMA_URL=http://ollama:11434
# Model to use. Requires 8GB+ VRAM for 14B. Use qwen2.5:7b for 6GB VRAM.
OLLAMA_MODEL=qwen2.5:14b
# Keep model loaded in VRAM between requests (seconds). -1 = forever.
OLLAMA_KEEP_ALIVE=3600

# =============================================================================
# OPEN WEBUI
# =============================================================================
# Change this to a random string before first run.
WEBUI_SECRET_KEY=change-this-to-a-random-string

# Generated after first login: Settings > Account > API Keys > New Key
# The agent needs this to post proactive alerts to the SOC Monitor chat.
# Leave blank on first run - the agent will start without notifications.
WEBUI_API_KEY=

# The ID of the dedicated SOC Monitor conversation.
# Leave blank on first run. The agent will create the chat and print its ID
# to the logs. Set it here and restart the agent to enable push alerts.
WEBUI_MONITOR_CHAT_ID=

# =============================================================================
# AGENT BEHAVIOUR
# =============================================================================
# How often the agent polls for new cases (minutes).
POLL_INTERVAL_MINUTES=15

# If true, the agent will autonomously execute ALL playbook steps including
# response actions (blocking IPs, disabling accounts, isolating hosts).
# Keep false unless you fully trust the agent's decisions. Default: false.
AUTO_EXECUTE_PLAYBOOKS=false

# TheHive severity level (1-4) at which to escalate a case immediately.
# 3 = High, 4 = Critical. Default: 3.
ESCALATION_SEVERITY_THRESHOLD=3

# Minimum Wazuh rule level to pull into analysis (0-15). Default: 3.
# Matches the level filter on your existing Shuffle integration.
SIEM_MIN_LEVEL=3

# How many hours back to look when pulling SIEM logs for a case. Default: 24.
LOG_LOOKBACK_HOURS=24

# Logging verbosity. Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
